{
  "permissions": {
    "allow": [
      "Bash(git config *)",
      "Bash(git commit -m ' *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git status *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git log *)",
      "Bash(git diff *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$changes = git status --porcelain 2>$null; if ($changes) { git add -A 2>$null; git commit -m 'Auto-snapshot from Claude session' --quiet 2>$null; git push origin main --quiet 2>$null }",
            "async": true,
            "timeout": 60,
            "statusMessage": "Auto-pushing changes to origin/main"
          }
        ]
      }
    ]
  }
}
