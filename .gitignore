# 🔱 NEXUM CORE - Git Ignore Rules
# ================================

# Environment Variables (CRITICAL)
.env
.env.local
config.local.js

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Storage & Runtime Logs
storage/logs/*
storage/temp/*
storage/memory/*
storage/exports/*
registry/apps/*
registry/bots/*
registry/agents/*
!storage/logs/.gitkeep
!storage/memory/.gitkeep
!registry/apps/.gitkeep

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# IDES
.vscode/
.idea/
*.swp
*.swo
